# === Drift Playground — live meaning-pass configuration ===
# Copy this file to `.env` and fill in the values. `.env` is gitignored.
# All variables below are read only by `npm run meaning:live`. The UI
# never reads them; React re-renders cannot trigger live API calls.

# Anthropic API key. Required when ENABLE_LIVE_MEANING=true.
# Get one at https://console.anthropic.com/. Never commit a real key.
ANTHROPIC_API_KEY=sk-ant-REPLACE-ME

# Master safety switch. Live API calls happen ONLY when this is "true"
# AND a key is present AND the call is invoked through `npm run meaning:live`.
# Default is false.
ENABLE_LIVE_MEANING=false

# Model ID used by the live meaning pass.
# Default: claude-sonnet-4-6 (recommended for the meaning task).
# Alternatives: claude-opus-4-7 (slower/pricier, higher judgment quality),
#               claude-haiku-4-5-20251001 (faster/cheaper, not the floor).
MEANING_MODEL=claude-sonnet-4-6

# Maximum number of model calls allowed in a single live run.
# The runner refuses to start past this and refuses to make the (N+1)th call.
# Counts retries.
MEANING_CALL_CAP=50

# Where the disk cache lives, relative to playground/.
# The directory is gitignored. Survives `npm run dev` restarts so previously
# judged items don't re-bill on the next CLI run.
MEANING_CACHE_DIR=.meaning-cache
